    console.error(`API proxy error [${targetHost}${targetPath}]:`, e.message);
    res.writeHead(502);
    res.end("API proxy error: " + e.message);
  });
  if (req.method !== "GET" && req.method !== "HEAD") {
    req.pipe(proxy);
  } else {
    proxy.end();
  }
}

